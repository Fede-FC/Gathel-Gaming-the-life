// =====================================================================
// Gathel - Gaming the life
// Diseño de Base de Datos (SQL Server)
// Generado a partir de specification.md v2.0 (13 de Junio de 2026)
// Incorpora recomendaciones de los agentes de IA
// =====================================================================

Project Gathel {
  database_type: 'SQL Server'
  Note: '''
    Plataforma de predicciones basada en eventos de la vida real.
    Convenciones:
    - PK surrogate IDENTITY en todas las tablas.
    - created_at / updated_at en DATETIME2 (UTC).
    - checksum SHA-256 para auditoría en tablas críticas.
    - Sin hardcoding: tasas, configuraciones y constantes viven en tablas/catálogos.
  '''
}

// =====================================================================
// CATÁLOGOS
// =====================================================================

Table PropositionStatus {
  status_id    int          [pk, increment]
  status_code  varchar(30)  [not null, unique, note: 'PENDING, ACTIVE, PREDICTION_CLOSED, RESOLVED, REJECTED, CANCELLED']
  description  varchar(200)
  enabled      bit          [not null, default: 1]
  created_at   datetime2    [not null, default: `GETUTCDATE()`]
}

Table SocialNetwork {
  social_network_id int          [pk, increment]
  network_code      varchar(20)  [not null, unique, note: 'INSTAGRAM, TIKTOK, TWITTER']
  network_name      varchar(50)  [not null]
  url               varchar(500)
  api_url           varchar(500)
  api_config        nvarchar(max) [note: 'JSON: keys, scopes, etc.']
  enabled           bit          [not null, default: 1]
  created_at        datetime2    [not null, default: `GETUTCDATE()`]
}

Table CurrencyType {
  currency_type_id int          [pk, increment]
  currency_code    varchar(30)  [not null, unique, note: 'POINTS, USD, EUR, ...']
  currency_name    varchar(50)  [not null]
  currency_symbol  varchar(10)
  is_virtual       bit          [not null, note: 'TRUE: moneda virtual; FALSE: dinero real']
  decimal_places   int          [not null, default: 0]
  enabled          bit          [not null, default: 1]
  created_at       datetime2    [not null, default: `GETUTCDATE()`]
  Note: 'La tasa de cambio se traslada a ExchangeRate (histórico).'
}

Table ExchangeRate {
  exchange_rate_id int           [pk, increment]
  currency_type_id int           [not null]
  rate_to_usd      decimal(18,4) [not null]
  effective_date   datetime2     [not null]
  created_at       datetime2     [not null, default: `GETUTCDATE()`]

  indexes {
    (currency_type_id, effective_date) [name: 'idx_exchange_rate_currency_date', note: 'effective_date DESC; tasa vigente por fecha']
  }
  Note: 'Append-only. La tasa vigente es la de mayor effective_date <= fecha de la transacción.'
}

Table TransactionType {
  transaction_type_id int          [pk, increment]
  type_code           varchar(30)  [not null, unique, note: 'DEPOSIT, WITHDRAWAL, COMMISSION, WINNING']
  description         varchar(200)
  applies_to          varchar(10)  [not null, note: 'POINTS, MONEY o BOTH']
  enabled             bit          [not null, default: 1]
  created_at          datetime2    [not null, default: `GETUTCDATE()`]
}

Table EventType {
  event_type_id int          [pk, increment]
  type_code     varchar(40)  [not null, unique, note: 'PROPOSITION_CREATED, VOTE_CAST, PREDICTION_MADE, ...']
  description   varchar(200)
  enabled       bit          [not null, default: 1]
  created_at    datetime2    [not null, default: `GETUTCDATE()`]
}

Table AIModel {
  ai_model_id int          [pk, increment]
  model_code  varchar(50)  [not null, unique, note: 'GPT4, CLAUDE3, ...']
  model_name  varchar(100) [not null]
  version     varchar(20)  [not null]
  enabled     bit          [not null, default: 1]
  created_at  datetime2    [not null, default: `GETUTCDATE()`]
}

Table AIProvider {
  ai_provider_id int          [pk, increment]
  provider_code  varchar(30)  [not null, unique, note: 'OPENAI, ANTHROPIC']
  provider_name  varchar(100) [not null]
  enabled        bit          [not null, default: 1]
  created_at     datetime2    [not null, default: `GETUTCDATE()`]
}

// =====================================================================
// AUTENTICACIÓN Y REDES SOCIALES
// =====================================================================

Table Player {
  player_id             int          [pk, increment]
  username              varchar(50)  [not null, unique]
  email                 varchar(150) [not null, unique]
  password_hash         varchar(256) [not null, note: 'Argon2id / bcrypt (cost >= 12); algoritmo en backend']
  display_name          varchar(100)
  balance_points        bigint       [not null, default: 100, note: 'Desnormalizado por performance; sincronizado vía trigger']
  balance_version       int          [not null, default: 1, note: 'Optimistic locking']
  last_transaction_date datetime2
  enabled               bit          [not null, default: 1]
  created_at            datetime2    [not null, default: `GETUTCDATE()`]
  updated_at            datetime2    [not null, default: `GETUTCDATE()`]
  updated_by            varchar(100)
  checksum              varchar(64)

  indexes {
    created_at [name: 'idx_player_created']
  }
}

Table SocialAccount {
  social_account_id int          [pk, increment]
  player_id         int          [not null]
  social_network_id int          [not null]
  account_username  varchar(100) [not null]
  is_verified       bit          [not null, default: 0]
  enabled           bit          [not null, default: 1]
  created_at        datetime2    [not null, default: `GETUTCDATE()`]
  updated_at        datetime2    [not null, default: `GETUTCDATE()`]

  indexes {
    (player_id, social_network_id) [unique, name: 'idx_social_account_unique']
  }
  Note: 'access_token movido a SocialAccountSession (tokens rotan).'
}

Table SocialAccountSession {
  session_id              bigint       [pk, increment]
  social_account_id       int          [not null]
  access_token_encrypted  varchar(500) [not null, note: 'Always Encrypted']
  refresh_token_encrypted varchar(500) [note: 'Always Encrypted']
  token_expires_at        datetime2
  encryption_key_id       int          [note: 'Referencia a key store']
  last_used_at            datetime2
  rotation_count          int          [not null, default: 0]
  is_active               bit          [not null, default: 1]
  created_at              datetime2    [not null, default: `GETUTCDATE()`]
  invalidated_at          datetime2
}

// =====================================================================
// PROPOSICIONES Y PREDICCIONES
// =====================================================================

Table Proposition {
  proposition_id       int           [pk, increment]
  creator_player_id    int           [not null]
  target_player_id     int           [not null]
  title                varchar(150)  [not null]
  description          varchar(1000) [not null]
  status_id            int           [not null]
  ai_review_result     varchar(20)   [note: 'APPROVED, REJECTED, PENDING']
  ai_review_detail     varchar(500)
  rejection_reason     varchar(500)
  voting_ends_at       datetime2
  prediction_ends_at   datetime2
  is_accepted_by_target bit          [not null, default: 0]
  is_fulfilled         bit
  resolved_at          datetime2
  enabled              bit           [not null, default: 1]
  created_at           datetime2     [not null, default: `GETUTCDATE()`]
  updated_at           datetime2     [not null, default: `GETUTCDATE()`]
  checksum             varchar(64)
  checksum_timestamp   datetime2     [note: 'Momento del cálculo del checksum (no modificable)']

  indexes {
    status_id          [name: 'idx_proposition_status', note: 'INCLUDE(creator_player_id, target_player_id, title, prediction_ends_at) WHERE enabled=1']
    (creator_player_id, created_at) [name: 'idx_proposition_creator', note: 'created_at DESC; INCLUDE(status_id, title, is_accepted_by_target)']
    (target_player_id, created_at)  [name: 'idx_proposition_target', note: 'created_at DESC; INCLUDE(status_id, title, creator_player_id)']
    prediction_ends_at [name: 'idx_proposition_prediction_ends', note: 'WHERE status_id IN (2,3) AND enabled=1']
    created_at         [name: 'idx_proposition_created']
  }
  Note: 'CHECK(creator_player_id <> target_player_id). Cambios auditados en PropositionAudit vía trigger.'
}

Table Vote {
  vote_id        bigint    [pk, increment]
  proposition_id int       [not null]
  player_id      int       [not null]
  created_at     datetime2 [not null, default: `GETUTCDATE()`]
  checksum       varchar(64)

  indexes {
    (proposition_id, player_id) [unique, name: 'idx_vote_unique']
    proposition_id [name: 'idx_vote_proposition', note: 'INCLUDE(player_id)']
  }
  Note: 'RLS (VoteSecurityPolicy): sólo el target de la proposición (y Admin) ve todos los votos; cada jugador ve su propio voto.'
}

Table Prediction {
  prediction_id    bigint        [pk, increment]
  proposition_id   int           [not null]
  player_id        int           [not null]
  amount           decimal(18,4) [not null, note: 'CHECK(amount > 0); si moneda virtual, amount <= 1 (validado en SP)']
  currency_type_id int           [not null]
  direction        bit           [not null, note: '1: se cumple, 0: no se cumple']
  result           varchar(10)   [note: 'PENDING, WON, LOST']
  created_at       datetime2     [not null, default: `GETUTCDATE()`]
  updated_at       datetime2     [not null, default: `GETUTCDATE()`]
  checksum         varchar(64)

  indexes {
    proposition_id [name: 'idx_prediction_proposition', note: 'INCLUDE(player_id, direction, amount, currency_type_id, result)']
    (player_id, created_at) [name: 'idx_prediction_player', note: 'created_at DESC; INCLUDE(proposition_id, direction, result, amount)']
    result [name: 'idx_prediction_result_pending', note: "WHERE result='PENDING'; INCLUDE(proposition_id, player_id, amount)"]
  }
  Note: 'Predicción con "ambos" (puntos y dinero) = dos filas (una POINTS, una de dinero).'
}

Table PropositionEvidence {
  evidence_id       bigint       [pk, increment]
  proposition_id    int          [not null]
  post_id           varchar(100) [note: 'ID del post en la red social']
  evidence_url      varchar(500)
  evidence_type     varchar(20)  [not null, note: 'PHOTO, VIDEO, STORY, REEL, TWEET, POST']
  social_network_id int
  created_at        datetime2    [not null, default: `GETUTCDATE()`]
  checksum          varchar(64)

  indexes {
    post_id [name: 'idx_evidence_post']
  }
}

// =====================================================================
// TRANSACCIONES
// =====================================================================

Table Transaction {
  transaction_id      bigint        [pk, increment]
  player_id           int           [not null]
  currency_type_id    int           [not null]
  amount              decimal(18,4) [not null, note: 'Positivo: ingreso; negativo: egreso']
  running_balance     decimal(18,4) [not null, note: 'Balance tras la transacción']
  transaction_type_id int           [not null]
  reference_type      varchar(30)   [note: 'PROPOSITION, PREDICTION, ...']
  reference_id        bigint
  description         varchar(300)
  created_at          datetime2     [not null, default: `GETUTCDATE()`]
  checksum            varchar(64)

  indexes {
    (player_id, currency_type_id, created_at) [name: 'idx_transaction_player_currency', note: 'created_at DESC; INCLUDE(amount, running_balance, transaction_type_id)']
    (reference_type, reference_id) [name: 'idx_transaction_reference', note: 'INCLUDE(player_id, amount, created_at)']
  }
  Note: 'RLS (TransactionSecurityPolicy): cada jugador sólo ve sus transacciones; Admin ve todo.'
}

// =====================================================================
// AUDITORÍA E IA
// =====================================================================

Table AIReviewLog {
  review_id            bigint        [pk, increment]
  proposition_id       int           [not null]
  ai_model_id          int           [not null]
  ai_provider_id       int           [not null]
  review_result        varchar(20)   [not null, note: 'APPROVED, REJECTED, PENDING']
  confidence_score     decimal(5,4)
  rejection_categories varchar(500)  [note: 'JSON array']
  request_payload      nvarchar(max) [note: 'CHECK(ISJSON(request_payload)=1)']
  response_payload     nvarchar(max) [note: 'CHECK(ISJSON(response_payload)=1)']
  review_details       nvarchar(max)
  reviewed_at          datetime2     [not null]
  checksum             varchar(64)
}

Table GameEvent {
  event_id        bigint        [pk, increment]
  proposition_id  int           [note: 'Puede ser NULL']
  event_type_id   int           [not null]
  actor_player_id int           [not null]
  event_data      nvarchar(max) [note: 'CHECK(ISJSON(event_data)=1)']
  created_at      datetime2     [not null, default: `GETUTCDATE()`]
  checksum        varchar(64)

  indexes {
    (proposition_id, created_at) [name: 'idx_gameevent_proposition', note: 'created_at DESC; INCLUDE(event_type_id, actor_player_id)']
    (event_type_id, created_at)  [name: 'idx_gameevent_event_type', note: 'created_at DESC; INCLUDE(proposition_id, actor_player_id)']
  }
}

Table ProcessLog {
  log_id             bigint       [pk, increment]
  sp_name            varchar(100) [not null]
  action_description varchar(500)
  affected_table     varchar(50)
  affected_record_id bigint
  status             varchar(15)  [not null, note: 'SUCCESS, ERROR, PARTIAL']
  error_detail       varchar(max)
  executed_at        datetime2    [not null, default: `GETUTCDATE()`]
  executed_by        varchar(100)
}

Table PropositionAudit {
  audit_id       bigint       [pk, increment]
  proposition_id int          [not null]
  field_name     varchar(50)  [not null]
  old_value      varchar(max)
  new_value      varchar(max)
  changed_by     varchar(100) [not null]
  changed_at     datetime2    [not null, default: `GETUTCDATE()`]
  checksum       varchar(64)

  indexes {
    (proposition_id, changed_at) [name: 'idx_proposition_audit_prop_date', note: 'changed_at DESC']
    (changed_by, changed_at)     [name: 'idx_proposition_audit_changed_by', note: 'changed_at DESC']
    (field_name, changed_at)     [name: 'idx_proposition_audit_field', note: 'changed_at DESC']
  }
  Note: 'Append-only. Poblada por trigger tr_proposition_audit (AFTER UPDATE sobre Proposition).'
}

// =====================================================================
// RELACIONES (Foreign Keys)
// =====================================================================

Ref: ExchangeRate.currency_type_id > CurrencyType.currency_type_id [delete: restrict]

Ref: SocialAccount.player_id > Player.player_id [delete: cascade]
Ref: SocialAccount.social_network_id > SocialNetwork.social_network_id [delete: restrict]
Ref: SocialAccountSession.social_account_id > SocialAccount.social_account_id [delete: cascade]

Ref: Proposition.creator_player_id > Player.player_id [delete: restrict]
Ref: Proposition.target_player_id > Player.player_id [delete: restrict]
Ref: Proposition.status_id > PropositionStatus.status_id [delete: restrict]

Ref: PropositionEvidence.proposition_id > Proposition.proposition_id [delete: cascade]
Ref: PropositionEvidence.social_network_id > SocialNetwork.social_network_id [delete: restrict]

Ref: Vote.proposition_id > Proposition.proposition_id [delete: cascade]
Ref: Vote.player_id > Player.player_id [delete: restrict]

Ref: Prediction.proposition_id > Proposition.proposition_id [delete: cascade]
Ref: Prediction.player_id > Player.player_id [delete: restrict]
Ref: Prediction.currency_type_id > CurrencyType.currency_type_id [delete: restrict]

Ref: Transaction.player_id > Player.player_id [delete: restrict]
Ref: Transaction.currency_type_id > CurrencyType.currency_type_id [delete: restrict]
Ref: Transaction.transaction_type_id > TransactionType.transaction_type_id [delete: restrict]

Ref: GameEvent.proposition_id > Proposition.proposition_id [delete: cascade]
Ref: GameEvent.event_type_id > EventType.event_type_id [delete: restrict]
Ref: GameEvent.actor_player_id > Player.player_id [delete: restrict]

Ref: AIReviewLog.proposition_id > Proposition.proposition_id [delete: cascade]
Ref: AIReviewLog.ai_model_id > AIModel.ai_model_id [delete: restrict]
Ref: AIReviewLog.ai_provider_id > AIProvider.ai_provider_id [delete: restrict]

Ref: PropositionAudit.proposition_id > Proposition.proposition_id [delete: cascade]
