# Flyway Configuration - Copy to .env and fill with your values
# .env should be added to .gitignore

# SQL Server Connection
FLYWAY_URL=jdbc:sqlserver://localhost:1433;databaseName=GathelDB;encrypt=true;trustServerCertificate=true
FLYWAY_USER=sa
FLYWAY_PASSWORD=YourSecurePassword123!

# For Docker environment, use:
# FLYWAY_URL=jdbc:sqlserver://sql-server:1433;databaseName=GathelDB;encrypt=true;trustServerCertificate=true
# FLYWAY_USER=sa
# FLYWAY_PASSWORD=YourSecurePassword123!
