# Flyway Configuration - Copy to .env and fill with your values
# .env should be added to .gitignore
#
# ⚠️ IMPORTANTE: Con Docker Compose, estos valores NO son necesarios
# (Docker Compose usa los valores en docker-compose.yml)
#
# Use este archivo SOLO si ejecuta Flyway localmente sin Docker

# SQL Server Connection (Local - Sin Docker)
FLYWAY_URL=jdbc:sqlserver://localhost:1433;databaseName=GathelDB;encrypt=true;trustServerCertificate=true
FLYWAY_USER=sa
FLYWAY_PASSWORD=YourSecurePassword123!

# ============================================================================
# PARA USAR CON DOCKER COMPOSE:
# ============================================================================
# 1. Instala Docker: https://www.docker.com/products/docker-desktop
# 2. En la raíz del proyecto:
#    ./scripts/docker-setup.sh up
# 3. Listo - Flyway corre automáticamente en un contenedor
# 4. NO necesitas este archivo .env
# ============================================================================
